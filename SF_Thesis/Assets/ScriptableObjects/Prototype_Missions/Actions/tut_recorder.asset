  m_Script: {fileID: 11500000, guid: 6375fd59a2a59f84db05789dc2091b51, type: 3}
  m_Name: tut_recorder
  m_EditorClassIdentifier: Assembly-CSharp::TutorialDefinition
  tutorialId: tut.recorder
  text: 'Recorder Controls

    ------------------

    - Press E to pick up/drop
    the recorder.

    - Hold F to record a message.

    - Tap F to play the recorded
    message.

    - Tap F again to stop playback.

    - Playback boosts the volume
    and intensity of the original recording.


    Throwing

    ----------

    -
    Hold Left Mouse Button to charge a throw.

    - Release Left Mouse Button to
    throw.

    - You can charge a throw, play the message, then release to throw
    it.

    - Right Mouse Button cancels the throw.'
  pauseTime: 1
  oneShot: 1
  allowContinueAfterSeconds: 5
  showContinueHintAfterSeconds: 5
