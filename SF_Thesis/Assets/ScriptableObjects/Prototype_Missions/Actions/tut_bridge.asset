  m_Name: tut_bridge
  m_EditorClassIdentifier: Assembly-CSharp::TutorialDefinition
  tutorialId: tut.bridges
  text: "To extend or retract a bridge, issue a verbal command:\n\u201CExtend [bridge
    number]\u201D or \u201CRetract [bridge number].\u201D\n\nThe bridge number is
    displayed in the immediate vicinity of the structure.\n\nWarning: Maintenance
    bridges generate significant noise.\nConsider nearby personnel before activation."
  pauseTime: 1
  oneShot: 1
  allowContinueAfterSeconds: 5
  showContinueHintAfterSeconds: 5
